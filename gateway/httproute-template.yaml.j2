apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: {{ deployment_id }}-route
  namespace: {{ namespace }}
  labels:
    deployhub.jeneeldumasia.codes/project: "{{ project_name }}"
    deployhub.jeneeldumasia.codes/deployment: "{{ deployment_id }}"
spec:
  parentRefs:
    - name: deployhub-gateway
      namespace: deployhub-system
  hostnames:
    # Host-based routing using wildcard domains (*.deployhub.jeneeldumasia.codes is handled by Gateway)
    - "{{ deployment_id[:8] }}.{{ project_name }}.deployhub.jeneeldumasia.codes"
  rules:
    - backendRefs:
        - name: {{ service_name }}
          port: {{ service_port }}
